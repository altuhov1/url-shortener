FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/httpBack ./cmd/httpBack

FROM alpine:3.20

RUN adduser -D -u 10001 appuser
USER appuser

WORKDIR /app
COPY --from=builder /out/httpBack /app/httpBack

EXPOSE 8080
ENTRYPOINT ["/app/httpBack"]
